<Window x:Class="AISPVZ.Views.StorageCellsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление ячейками" Height="700" Width="1100"
        MinWidth="800" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="УПРАВЛЕНИЕ ЯЧЕЙКАМИ" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Управление ячейками хранения" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Filter Panel -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
                CornerRadius="8" Padding="12" Margin="0,0,0,16">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Добавить" Command="{Binding StartAddCommand}" Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="Изменить" Command="{Binding StartEditCommand}" Style="{StaticResource DefaultButtonStyle}"/>

                <Rectangle Width="1" Fill="{StaticResource DividerBrush}" Margin="10,5"/>

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="140"
                         ToolTip="Поиск по коду или комментарию..."
                         Margin="0,0,8,0"/>

                <TextBox Text="{Binding FilterZone, UpdateSourceTrigger=PropertyChanged}"
                         Width="80"
                         ToolTip="Фильтр по зоне..."
                         Margin="0,0,8,0"/>

                <CheckBox Content="Только занятые" IsChecked="{Binding FilterBusyOnly, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>

                <Button Content="Применить" Command="{Binding DoApplyFilterCommand}" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="CSV" Style="{StaticResource ButtonRevealStyle}" Click="ExportClick"/>
                <Button Content="Схема" Command="{Binding ToggleVisualSchemeCommand}" Style="{StaticResource DefaultButtonStyle}"/>
            </WrapPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Visual Scheme -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="8" Padding="16"
                    Visibility="{Binding ShowVisualScheme, Converter={StaticResource BoolToVisConv}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SchemeCells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="90" Height="70" Margin="4"
                                        Background="{Binding IsBusy, Converter={StaticResource CellStatusToColorConv}}"
                                        Foreground="White" BorderThickness="0"
                                        Command="{Binding DataContext.OnCellDoubleClickCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="4">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CellCode}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Zone}" FontSize="10" Opacity="0.8" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding MaxWeightKg, StringFormat='{}{0}кг'}" FontSize="9" Opacity="0.7" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Cells Table -->
            <DataGrid Grid.Column="0"
                      Visibility="{Binding ShowVisualScheme, Converter={StaticResource InvBoolToVisConv}}"
                      ItemsSource="{Binding Cells}"
                      SelectedItem="{Binding SelectedCell}"
                      AutoGenerateColumns="False"
                      MinHeight="380"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="КОД ЯЧЕЙКИ" Binding="{Binding CellCode}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ЗОНА" Binding="{Binding Zone}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="СТАТУС" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding IsBusy, Converter={StaticResource CellStatusToColorConv}}"
                                        CornerRadius="6" Padding="10,6" Margin="2" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding IsBusy, Converter={StaticResource CellStatusToBoolConv}}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="МАКС. ВЕС (КГ)" Binding="{Binding MaxWeightKg, StringFormat=N1}" Width="150"/>
                    <DataGridTextColumn Header="КОММЕНТАРИЙ" Binding="{Binding Comment}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Edit Panel -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="8" Padding="18" Width="340" Margin="12,0,0,0"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding SelectedCell.Id, Converter={StaticResource NullToTextConv}, FallbackValue='НОВАЯ ЯЧЕЙКА'}"
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                        <Button Grid.Column="1" Command="{Binding CancelEditCommand}"
                                Style="{StaticResource ButtonRevealStyle}" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Padding="8,4"/>
                    </Grid>

                    <TextBlock Text="Код ячейки *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding NewCellCode, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="A-01"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Зона" 
           FontSize="11" 
           Foreground="{StaticResource TextSecondaryBrush}" 
           Margin="0,0,0,4"/>

                    <ComboBox Text="{Binding NewCellZone, UpdateSourceTrigger=PropertyChanged}"
          IsEditable="True"
          Margin="0,0,0,12"
          Background="White"
          Foreground="Black">

                        <ComboBox.Resources>
                            <!-- Стиль для редактируемого текстового поля -->
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="SelectionBrush" Value="#0078D4"/>
                                <Setter Property="SelectionOpacity" Value="0.5"/>
                            </Style>

                            <!-- Стиль для элементов выпадающего списка -->
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#E6F0FA"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#0078D4"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <!-- Системные цвета для выпадающего окна -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black"/>
                        </ComboBox.Resources>

                        <ComboBoxItem Content="A"/>
                        <ComboBoxItem Content="B"/>
                        <ComboBoxItem Content="C"/>
                    </ComboBox>

                    <TextBlock Text="Макс. вес (кг)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewCellMaxWeight, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="30"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Комментарий" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewCellComment, UpdateSourceTrigger=PropertyChanged}" 
                             ToolTip="Дополнительная информация"
                             AcceptsReturn="True"
                             Height="70" TextWrapping="Wrap"
                             Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Сохранить" Command="{Binding SaveCellCommand}" Style="{StaticResource AccentButtonStyle}"/>
                        <Button Content="Отмена" Command="{Binding CancelEditCommand}" Style="{StaticResource ButtonRevealStyle}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="11" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
