<Window x:Class="AISPVZ.Views.EmployeesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сотрудники" Height="600" Width="850"
        WindowStartupLocation="CenterScreen"
        MinWidth="700" MinHeight="450"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="СОТРУДНИКИ" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- Кнопки действий -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
                CornerRadius="8" Padding="12" Margin="0,0,0,15">
            <WrapPanel Orientation="Horizontal">
                <Button Content="Добавить" Command="{Binding StartAddCommand}" Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="Изменить" Command="{Binding StartEditCommand}" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="Деактивировать" Command="{Binding DeactivateEmployeeCommand}" Style="{StaticResource ButtonRevealStyle}"/>
                <Button Content="Excel" Style="{StaticResource ButtonRevealStyle}" Click="ExportExcelClick"/>
            </WrapPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Таблица сотрудников -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Employees}"
                      SelectedItem="{Binding SelectedEmployee}"
                      AutoGenerateColumns="False"
                      Margin="0,0,10,0"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="ЛОГИН" Binding="{Binding Login}" Width="120"/>
                    <DataGridTextColumn Header="РОЛЬ" Binding="{Binding Role, Converter={StaticResource RoleToTextConv}}" Width="120"/>
                    <DataGridTemplateColumn Header="СТАТУС" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToActiveTextConv}}"
                                           Foreground="{Binding IsActive, Converter={StaticResource BoolToStatusColorConv}}"
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Панель редактирования -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="8" Padding="18" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="ДАННЫЕ СОТРУДНИКА" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>

                    <TextBlock Text="ФИО *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                    <TextBox Text="{Binding FullName}"
                             ToolTip="Фамилия Имя Отчество"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Логин *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Login}"
                             ToolTip="ivanov"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Пароль" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBox"
                                 ToolTip="Оставьте пустым, чтобы не менять"
                                 Margin="0,0,0,12"/>

                    <TextBlock Text="Роль" 
           FontSize="11" 
           Foreground="{StaticResource TextSecondaryBrush}" 
           Margin="0,0,0,4"/>

                    <ComboBox ItemsSource="{Binding RoleOptions}"
          SelectedValuePath="Key"
          DisplayMemberPath="Value"
          SelectedValue="{Binding SelectedRole}"
          Margin="0,0,0,12"
          Background="White"
          Foreground="Black">

                        <ComboBox.Resources>
                            <!-- Стиль для элементов выпадающего списка -->
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#E6F0FA"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#0078D4"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <!-- Системные цвета для выпадающего окна -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black"/>
                        </ComboBox.Resources>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Сохранить" Command="{Binding SaveEmployeeCommand}" Style="{StaticResource AccentButtonStyle}"/>
                        <Button Content="Отмена" Command="{Binding CancelEditCommand}" Style="{StaticResource ButtonRevealStyle}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
