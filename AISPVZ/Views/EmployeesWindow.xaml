<Window x:Class="AISPVZ.Views.EmployeesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сотрудники" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        MinWidth="700" MinHeight="450">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#FF6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF6366F1"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF6366F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Styles -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MinHeight" Value="48"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF6366F1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2D2D44"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#FF1F2937"/>
            <Setter Property="AlternatingRowBackground" Value="#FF2D2D44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="48"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="👨‍💼 СОТРУДНИКИ" FontSize="22" FontWeight="Bold"/>
        </StackPanel>

        <!-- Кнопки действий -->
        <Border Grid.Row="1" Background="#FF1F2937" CornerRadius="10" Padding="12" Margin="0,0,0,15">
            <WrapPanel Orientation="Horizontal">
                <Button Content="➕ Добавить" Command="{Binding StartAddCommand}" Background="#FF10B981" Margin="0,0,8,0"/>
                <Button Content="✏️ Изменить" Command="{Binding StartEditCommand}" Background="#FF3B82F6" Margin="0,0,8,0"/>
                <Button Content="🚫 Деактивировать" Command="{Binding DeactivateEmployeeCommand}" Background="#FFEF4444"/>
            </WrapPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Таблица сотрудников -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Employees}"
                      SelectedItem="{Binding SelectedEmployee}"
                      AutoGenerateColumns="False"
                      Margin="0,0,10,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="ЛОГИН" Binding="{Binding Login}" Width="140"/>
                    <DataGridTextColumn Header="РОЛЬ" Binding="{Binding Role, Converter={StaticResource RoleToTextConv}}" Width="140"/>
                    <DataGridTemplateColumn Header="СТАТУС" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToActiveTextConv}}"
                                           Foreground="{Binding IsActive, Converter={StaticResource BoolToStatusColorConv}}"
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Панель редактирования -->
            <Border Grid.Column="1" Background="#FF1F2937" CornerRadius="10" Padding="16" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="📝 ДАННЫЕ СОТРУДНИКА" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                    <TextBlock Text="ФИО *" Margin="0,0,0,4" FontSize="12"/>
                    <TextBox Text="{Binding FullName}" Margin="0,0,0,12"/>

                    <TextBlock Text="Логин *" Margin="0,0,0,4" FontSize="12"/>
                    <TextBox Text="{Binding Login}" Margin="0,0,0,12"/>

                    <TextBlock Text="Пароль" Margin="0,0,0,4" FontSize="12"/>
                    <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

                    <TextBlock Text="Роль" Margin="0,0,0,4" FontSize="12"/>
                    <ComboBox SelectedItem="{Binding SelectedRole}" Margin="0,0,0,16">
                        <ComboBoxItem Content="Оператор" Tag="Operator"/>
                        <ComboBoxItem Content="Администратор" Tag="Admin"/>
                    </ComboBox>

                    <WrapPanel Orientation="Horizontal">
                        <Button Content="💾 Сохранить" Command="{Binding SaveEmployeeCommand}" Background="#FF10B981" MinWidth="90"/>
                        <Button Content="❌ Отмена" Command="{Binding CancelEditCommand}" Background="#FF374151" MinWidth="90"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="#FF4ADE80" Margin="0,12,0,0" FontSize="11"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>