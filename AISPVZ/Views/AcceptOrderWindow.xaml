<Window x:Class="AISPVZ.Views.AcceptOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приёмка заказа"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

       
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,16,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="ПРИЁМКА ЗАКАЗА" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" Foreground="{StaticResource TextPrimaryBrush}"/>

                    
                    <TextBlock Text="ШТРИХКОД ЗАКАЗА *" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="BarcodeInput"
                             Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Введите или отсканируйте штрихкод"
                             FontSize="14" FontFamily="Consolas"
                             Margin="0,0,0,14"/>

                    <!-- Marketplace -->
                    <TextBlock Text="МАРКЕТПЛЕЙС" 
           FontSize="10" 
           FontWeight="SemiBold" 
           Foreground="{StaticResource TextSecondaryBrush}" 
           Margin="0,0,0,4"/>

                    <ComboBox Text="{Binding MarketplaceName}"
          IsEditable="True"
          ToolTip="Выберите или введите маркетплейс"
          Margin="0,0,0,14"
          Background="White"
          Foreground="Black">

                        <!-- Стиль для редактируемого текстового поля внутри ComboBox -->
                        <ComboBox.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="SelectionBrush" Value="#0078D4"/>
                                <Setter Property="SelectionOpacity" Value="0.5"/>
                            </Style>

                            <!-- Стиль для выпадающего списка -->
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#E6F0FA"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#0078D4"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <!-- Системные цвета для выпадающего окна -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black"/>
                        </ComboBox.Resources>

                        <ComboBoxItem Content="Ozon"/>
                        <ComboBoxItem Content="Wildberries"/>
                        <ComboBoxItem Content="Яндекс.Маркет"/>
                        <ComboBoxItem Content="Другое"/>
                    </ComboBox>

                    <!-- Cell -->
                    <!-- Cell -->
                    <TextBlock Text="ЯЧЕЙКА ХРАНЕНИЯ *" 
           FontSize="10" 
           FontWeight="SemiBold" 
           Foreground="{StaticResource TextSecondaryBrush}" 
           Margin="0,0,0,4"/>

                    <ComboBox ItemsSource="{Binding FreeCells}"
          SelectedItem="{Binding SelectedCell}"
          DisplayMemberPath="CellCode"
          ToolTip="Выберите свободную ячейку"
          Margin="0,0,0,14"
          Background="White"
          Foreground="Black">

                        <ComboBox.Resources>
                            <!-- Стиль для выпадающего списка -->
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Style.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#E6F0FA"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#0078D4"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <!-- Системные цвета для выпадающего окна -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black"/>
                        </ComboBox.Resources>
                    </ComboBox>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,0,0,14"/>
                    <TextBlock Text="ДАННЫЕ КЛИЕНТА" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>

                    <!-- Client Name -->
                    <TextBlock Text="ФИО КЛИЕНТА *" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Фамилия Имя Отчество"
                             Margin="0,0,0,14"/>

                    <!-- Phone -->
                    <TextBlock Text="ТЕЛЕФОН" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ClientPhone, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="+7 (999) 999-99-99"
                             helpers:PhoneMaskBehavior.IsEnabled="True"
                             xmlns:helpers="clr-namespace:AISPVZ.Helpers"
                             Margin="0,0,0,14"/>

                    <!-- Email -->
                    <TextBlock Text="EMAIL" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ClientEmail, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="email@example.com"
                             Margin="0,0,0,14"/>

                    <!-- Comment -->
                    <TextBlock Text="КОММЕНТАРИЙ" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Дополнительная информация"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="60"
                             Margin="0,0,0,14"/>

                    <!-- Total Summary -->
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ItemsCountText}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalAmountText}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <Button Content="Очистить"
                                Command="{Binding ClearFormCommand}"
                                Style="{StaticResource ButtonRevealStyle}"
                                HorizontalAlignment="Left"/>
                        <Button Content="Принять"
                                Command="{Binding SaveOrderCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Right"/>
                        <Button Content="Принять и печать"
                                Command="{Binding SaveAndPrintOrderCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Right"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{StaticResource SuccessBrush}" 
                               FontSize="12" TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ========== RIGHT PANEL: PRODUCTS ========== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Состав заказа" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Добавьте товары, входящие в заказ" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Добавить товар"
                        Command="{Binding AddItemCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
            </Grid>

            <!-- Add Item Form -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="8" Padding="16" Margin="0,0,0,12"
                    Visibility="{Binding IsAddingItem, Converter={StaticResource BoolToVisConv}}"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="НОВЫЙ ТОВАР" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="АРТИКУЛ" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding NewItemArticle, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Артикул товара"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="НАИМЕНОВАНИЕ *" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Название товара"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="КОЛ-ВО" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding NewItemQuantity, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Количество"
                                     TextAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="ЦЕНА (₽)" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding NewItemPrice, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Цена за единицу"
                                     TextAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Отмена" Command="{Binding CancelAddItemCommand}" Style="{StaticResource ButtonRevealStyle}"/>
                        <Button Content="Добавить" Command="{Binding ConfirmAddItemCommand}" Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Items List -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table Header -->
                    <Grid Grid.Row="0" Margin="8,4,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="АРТИКУЛ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="НАИМЕНОВАНИЕ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0"/>
                        <TextBlock Grid.Column="2" Text="КОЛ-ВО" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="ЦЕНА" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="СУММА" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Right" Margin="8,0,0,0"/>
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{Binding Items}" 
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding Article}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontFamily="Consolas"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ProductName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="-"
                                                Command="{Binding DataContext.DecrementQuantityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ButtonRevealStyle}" Padding="6,2" Margin="0,0,4,0" FontSize="11"/>
                                        <TextBlock Text="{Binding Quantity}" Width="28" TextAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                        <Button Content="+"
                                                Command="{Binding DataContext.IncrementQuantityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ButtonRevealStyle}" Padding="6,2" Margin="4,0,0,0" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="{Binding Price, StringFormat='{}{0:N2}'}" VerticalAlignment="Center" TextAlignment="Right" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    <TextBlock Grid.Column="4" Text="{Binding TotalPrice, StringFormat='{}{0:N2}'}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" Margin="8,0,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    <Button Grid.Column="5"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ButtonRevealStyle}"
                                            Content="&#xE74D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            Padding="6,2"
                                            Margin="4,0,0,0"
                                            FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
