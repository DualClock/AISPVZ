<Window x:Class="AISPVZ.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АИС ПВЗ - Главная"
        Width="1366" Height="768"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Стиль для кнопок меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Background" Value="#FF374151"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для карточек статистики -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== ЛЕВОЕ МЕНЮ ==================== -->
        <Border Grid.Column="0" Background="#FF16213E" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип и профиль -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="🏪 АИС ПВЗ" FontSize="20" FontWeight="Bold" Foreground="#FF6366F1"/>
                    <TextBlock Text="{Binding CurrentEmployee.FullName}" FontSize="13" Foreground="White" Margin="0,8,0,2" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding CurrentEmployee.Role, Converter={StaticResource RoleToTextConv}}" FontSize="11" Foreground="#FF9CA3AF"/>
                </StackPanel>

                <!-- Блок смены -->
                <Border Grid.Row="1" Background="#FF1F2937" CornerRadius="10" Padding="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="⏰ СМЕНА" FontSize="10" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding CurrentShift.StartTime, StringFormat='{}{0:HH:mm}'}" FontSize="20" FontWeight="Bold" Foreground="White"/>

                        <!-- Индикатор статуса смены -->
                        <Border Background="#33EF4444" CornerRadius="4" Padding="6,2" Margin="0,8,0,0"
                                Visibility="{Binding HasOpenShift, Converter={StaticResource BoolToVisConv}}">
                            <TextBlock Text="● Смена открыта" FontSize="10" Foreground="#FF4ADE80" HorizontalAlignment="Center"/>
                        </Border>

                        <Button Content="🔓 Открыть смену" Command="{Binding OpenShiftCommand}"
                                Visibility="{Binding HasOpenShift, Converter={StaticResource InvBoolToVisConv}}"
                                Style="{StaticResource MenuButtonStyle}" Background="#FF4ADE80" Foreground="#FF1A1A2E" Margin="0,8,0,0"/>
                        <Button Content="🔒 Закрыть смену" Command="{Binding CloseShiftCommand}"
                                Visibility="{Binding HasOpenShift, Converter={StaticResource BoolToVisConv}}"
                                Style="{StaticResource MenuButtonStyle}" Background="#FFEF4444" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Быстрые действия -->
                <StackPanel Grid.Row="2" Margin="0,0,0,16">
                    <TextBlock Text="⚡ БЫСТРЫЕ ДЕЙСТВИЯ" FontSize="10" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                    <Button Content="📦 Приёмка заказа (F2)" Command="{Binding NavigateToCommand}" CommandParameter="accept"
                            Style="{StaticResource MenuButtonStyle}" Background="#FF10B981"/>
                    <Button Content="📤 Выдача заказа (F3)" Command="{Binding NavigateToCommand}" CommandParameter="issue"
                            Style="{StaticResource MenuButtonStyle}" Background="#FF3B82F6"/>
                    <Button Content="↩️ Возврат (F4)" Command="{Binding NavigateToCommand}" CommandParameter="return"
                            Style="{StaticResource MenuButtonStyle}" Background="#FFF59E0B"/>
                </StackPanel>

                <!-- Справочники -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="📚 СПРАВОЧНИКИ" FontSize="10" Foreground="#FF6B7280" Margin="0,0,0,8"/>
                    <Button Content="📋 Ячейки" Command="{Binding NavigateToCommand}" CommandParameter="cells"
                            Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="👥 Клиенты" Command="{Binding NavigateToCommand}" CommandParameter="clients"
                            Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="👨‍💼 Сотрудники" Command="{Binding NavigateToCommand}" CommandParameter="employees"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisConv}}"/>
                    <Button Content="📊 Отчёты" Command="{Binding NavigateToCommand}" CommandParameter="reports"
                            Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="⚙️ Настройки" Command="{Binding NavigateToCommand}" CommandParameter="settings"
                            Style="{StaticResource MenuButtonStyle}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisConv}}"/>
                </StackPanel>

                <!-- Нижние кнопки -->
                <StackPanel Grid.Row="4" Margin="0,16,0,0">
                    <Button Content="🔄 Обновить" Command="{Binding RefreshDashboardCommand}"
                            Style="{StaticResource MenuButtonStyle}" Background="#FF4B5563"/>
                    <Button Content="🚪 Выход" Command="{Binding LogoutCommand}"
                            Style="{StaticResource MenuButtonStyle}" Background="#FFDC2626" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== ОСНОВНОЙ КОНТЕНТ ==================== -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель с поиском -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ДОБРО ПОЖАЛОВАТЬ" FontSize="10" Foreground="#FF6B7280"/>
                    <TextBlock Text="Панель управления" FontSize="24" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#FF1F2937" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="🔍 СКАНЕР ШТРИХКОДА" FontSize="10" Foreground="#FF6B7280"/>
                        <TextBox x:Name="ScannerBox" Text="{Binding BarcodeScan, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16" FontFamily="Consolas" Background="Transparent" 
                                 Foreground="White" BorderThickness="0" Padding="4,6"
                                 KeyDown="ScannerBox_KeyDown"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Карточки статистики -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="📦 НА ХРАНЕНИИ" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding Stats.OrdersInStorage, FallbackValue=0}" 
                                   FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="⚠️ ПРОСРОЧЕНО" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding Stats.OverdueOrders, FallbackValue=0}" 
                                   FontSize="32" FontWeight="Bold" Foreground="#FFEF4444" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="✅ ВЫДАНО СЕГОДНЯ" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding Stats.IssuedToday, FallbackValue=0}" 
                                   FontSize="32" FontWeight="Bold" Foreground="#FF4ADE80" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="↩️ ВОЗВРАТОВ" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBlock Text="{Binding Stats.ReturnsToday, FallbackValue=0}" 
                                   FontSize="32" FontWeight="Bold" Foreground="#FFF59E0B" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Списки заказов -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Просроченные заказы -->
                <Border Grid.Column="0" Background="#FF1F2937" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="⚠️ ПРОСРОЧЕННЫЕ ЗАКАЗЫ" FontSize="12" FontWeight="Bold" Foreground="#FFEF4444" Margin="0,0,0,10"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding OverdueOrders}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF2D2D44" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Barcode}" FontWeight="Bold" Foreground="White" FontSize="13"/>
                                                    <TextBlock Text="{Binding Client.FullName}" Foreground="#FF9CA3AF" FontSize="11" Margin="0,4,0,0"/>
                                                    <TextBlock Text="Ячейка: {Binding Cell.CellCode}" Foreground="#FF6366F1" FontSize="10" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#33EF4444" CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding PlannedIssueDate, StringFormat='{}{0:dd.MM}'}"
                                                               Foreground="#FFEF4444" FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Style.Triggers>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBox">
                                                            <Border Background="#FF2D2D44" CornerRadius="8" Padding="20">
                                                                <TextBlock Text="✅ Нет просроченных заказов" 
                                                                           Foreground="#FF4ADE80" HorizontalAlignment="Center" FontSize="12"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Заказы на сегодня -->
                <Border Grid.Column="1" Background="#FF1F2937" CornerRadius="10" Padding="14" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="⏰ ИСТЕКАЮТ СЕГОДНЯ" FontSize="12" FontWeight="Bold" Foreground="#FFF59E0B" Margin="0,0,0,10"/>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding ExpiringOrders}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FF2D2D44" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Barcode}" FontWeight="Bold" Foreground="White" FontSize="13"/>
                                                    <TextBlock Text="{Binding Client.FullName}" Foreground="#FF9CA3AF" FontSize="11" Margin="0,4,0,0"/>
                                                    <TextBlock Text="Ячейка: {Binding Cell.CellCode}" Foreground="#FF6366F1" FontSize="10" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#33FFA500" CornerRadius="4" Padding="6,3" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Marketplace, Converter={StaticResource MarketplaceToTextConv}}"
                                                               Foreground="#FFF59E0B" FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Style.Triggers>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBox">
                                                            <Border Background="#FF2D2D44" CornerRadius="8" Padding="20">
                                                                <TextBlock Text="📭 Нет заказов на сегодня" 
                                                                           Foreground="#FF9CA3AF" HorizontalAlignment="Center" FontSize="12"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>