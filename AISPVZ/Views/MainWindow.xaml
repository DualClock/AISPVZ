<Window x:Class="AISPVZ.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АИС ПВЗ - Главная"
        Width="1366" Height="900"
        MinWidth="900" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== ЛЕВОЕ МЕНЮ ==================== -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo and Profile -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="40" Height="40" Background="{StaticResource AccentBrush}" CornerRadius="8" Margin="0,0,12,0">
                            <TextBlock Text="PVZ" FontWeight="Bold" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="АИС ПВЗ" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding CurrentEmployee.FullName}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CurrentEmployee.Role, Converter={StaticResource RoleToTextConv}}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Shift Block -->
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <Expander Header="ТЕКУЩАЯ СМЕНА" IsExpanded="True" Foreground="{StaticResource TextPrimaryBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentShift.StartTime, StringFormat='{}{0:HH:mm}', FallbackValue='--:--'}" 
                                       FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding HasOpenShift, Converter={StaticResource BoolToVisConv}}">
                                <Ellipse Width="8" Height="8" Fill="#4ADE80" VerticalAlignment="Center"/>
                                <TextBlock Text="Смена открыта" FontSize="11" Foreground="#4ADE80" Margin="6,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding HasOpenShift, Converter={StaticResource InvBoolToVisConv}}">
                                <Ellipse Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center"/>
                                <TextBlock Text="Смена закрыта" FontSize="11" Foreground="#EF4444" Margin="6,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Открыть" Command="{Binding OpenShiftCommand}"
                                        Visibility="{Binding HasOpenShift, Converter={StaticResource InvBoolToVisConv}}"
                                        Style="{StaticResource AccentButtonStyle}"/>
                                <Button Content="Закрыть" Command="{Binding CloseShiftCommand}"
                                        Visibility="{Binding HasOpenShift, Converter={StaticResource BoolToVisConv}}"
                                        Style="{StaticResource ButtonRevealStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <!-- Quick Actions -->
                <StackPanel Grid.Row="2" Margin="0,0,0,16">
                    <TextBlock Text="БЫСТРЫЕ ДЕЙСТВИЯ" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Button Content="Приёмка заказа (F2)" Click="AcceptOrderButton_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Style="{StaticResource DefaultButtonStyle}"/>
                    <Button Content="Выдача заказа (F3)" Command="{Binding NavigateToCommand}" CommandParameter="issue"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Style="{StaticResource DefaultButtonStyle}"/>
                    <Button Content="Возврат (F4)" Command="{Binding NavigateToCommand}" CommandParameter="return"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Style="{StaticResource DefaultButtonStyle}"/>
                </StackPanel>

                <!-- References -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="СПРАВОЧНИКИ" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Button Content="Ячейки" Command="{Binding NavigateToCommand}" CommandParameter="cells"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Style="{StaticResource DefaultButtonStyle}"/>
                    <Button Content="Клиенты" Command="{Binding NavigateToCommand}" CommandParameter="clients"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Style="{StaticResource DefaultButtonStyle}"/>
                    <Button Content="Сотрудники" Command="{Binding NavigateToCommand}" CommandParameter="employees"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisConv}}"
                            Style="{StaticResource DefaultButtonStyle}"/>
                    <Button Content="Отчёты" Command="{Binding NavigateToCommand}" CommandParameter="reports"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Style="{StaticResource DefaultButtonStyle}"/>
                    <Button Content="Настройки" Command="{Binding NavigateToCommand}" CommandParameter="settings"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisConv}}"
                            Style="{StaticResource DefaultButtonStyle}"/>
                </StackPanel>

                <!-- Bottom Buttons -->
                <StackPanel Grid.Row="4" Margin="0,16,0,0">
                    <Button Content="Обновить" Command="{Binding RefreshDashboardCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Style="{StaticResource DefaultButtonStyle}"/>
                    <Button Content="Выход" Command="{Binding LogoutCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Style="{StaticResource ButtonRevealStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== MAIN CONTENT ==================== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Search Panel -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="ПАНЕЛЬ УПРАВЛЕНИЯ" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="Главная" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="СКАНЕР ШТРИХКОДА" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="ScannerBox" 
                                 Text="{Binding BarcodeScan, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Сканер штрихкода... Нажмите Enter"
                                 FontSize="14" FontFamily="Consolas"
                                 KeyDown="ScannerBox_KeyDown"/>

                        <TextBlock Text="ПОИСК ПО ТЕЛЕФОНУ" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,4"/>
                        <TextBox Text="{Binding PhoneSearch, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Введите телефон и нажмите Enter"
                                 FontSize="14"
                                 helpers:PhoneMaskBehavior.IsEnabled="True"
                                 xmlns:helpers="clr-namespace:AISPVZ.Helpers"
                                 KeyDown="PhoneSearchBox_KeyDown"/>
                        <TextBlock Text="{Binding SearchStatusMessage}" Foreground="{StaticResource ErrorBrush}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Stats Cards -->
                <Grid Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="НА ХРАНЕНИИ" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding Stats.OrdersInStorage, FallbackValue=0}"
                                       FontSize="36" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock Text="ПРОСРОЧЕНО" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding Stats.OverdueOrders, FallbackValue=0}"
                                       FontSize="36" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock Text="ВЫДАНО СЕГОДНЯ" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding Stats.IssuedToday, FallbackValue=0}"
                                       FontSize="36" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="ВОЗВРАТОВ" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding Stats.ReturnsToday, FallbackValue=0}"
                                       FontSize="36" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- All Orders in Storage -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,24,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="ЗАКАЗЫ НА ХРАНЕНИИ" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding InStorageOrders}"
                                  AutoGenerateColumns="False"
                                  MaxHeight="350"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ШТРИХКОД" Binding="{Binding Barcode}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="КЛИЕНТ" Binding="{Binding Client.FullName}" Width="*" MinWidth="150"/>
                                <DataGridTextColumn Header="ТЕЛЕФОН" Binding="{Binding Client.Phone}" Width="130"/>
                                <DataGridTextColumn Header="ЯЧЕЙКА" Binding="{Binding Cell.CellCode}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="МАРКЕТПЛЕЙС" Binding="{Binding Marketplace, Converter={StaticResource MarketplaceToTextConv}}" Width="120"/>
                                <DataGridTextColumn Header="СРОК ХРАНЕНИЯ" Binding="{Binding PlannedIssueDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Orders Lists -->
                <Grid Height="320" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Overdue Orders -->
                    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="ПРОСРОЧЕННЫЕ" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <ListView Grid.Row="1" ItemsSource="{Binding OverdueOrders}" 
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      BorderThickness="0" Background="Transparent">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock Text="{Binding Barcode}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas"/>
                                            <TextBlock Text="{Binding Client.FullName}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="Ячейка: "/><Run Text="{Binding Cell.CellCode, FallbackValue=--}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Expiring Orders -->
                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="ИСТЕКАЮТ СЕГОДНЯ" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <ListView Grid.Row="1" ItemsSource="{Binding ExpiringOrders}" 
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      BorderThickness="0" Background="Transparent">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,4">
                                            <TextBlock Text="{Binding Barcode}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas"/>
                                            <TextBlock Text="{Binding Client.FullName}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="Ячейка: "/><Run Text="{Binding Cell.CellCode, FallbackValue=--}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
