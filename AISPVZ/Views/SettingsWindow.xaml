<Window x:Class="AISPVZ.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="500" Width="600"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E">

    <Window.Resources>
        <!-- Стили для текстовых блоков -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Стиль для заголовков секций -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF6366F1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Стиль для подписей полей -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FF9CA3AF"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF3D3D5C"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FF6366F1"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Background" Value="#FF6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <!-- Стиль для полей с цифрами -->
        <Style x:Key="NumericTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="⚙️ НАСТРОЙКИ СИСТЕМЫ" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Настройка параметров работы ПВЗ" FontSize="11" Foreground="#FF6B7280" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Основная область с прокруткой -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,16">
            <StackPanel>

                <!-- Блок основных настроек -->
                <Border Background="#FF1F2937" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🏪 ОСНОВНЫЕ НАСТРОЙКИ" Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="Название ПВЗ" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="PvzNameBox" Text="ПВЗ Центральный" 
                                 ToolTip="Введите название пункта выдачи заказов"/>

                        <TextBlock Text="Адрес" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="AddressBox" Text="г. Москва, ул. Примерная, д. 1"
                                 ToolTip="Полный адрес пункта выдачи"/>

                        <TextBlock Text="Максимальный срок хранения (дней)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="MaxDaysBox" Text="14" 
                                 Style="{StaticResource NumericTextBoxStyle}"
                                 ToolTip="Количество дней хранения заказа до просрочки"/>

                        <TextBlock Text="Напоминание о просрочке (часов)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="ReminderHoursBox" Text="24" 
                                 Style="{StaticResource NumericTextBoxStyle}"
                                 ToolTip="За сколько часов до просрочки показывать напоминание"/>
                    </StackPanel>
                </Border>

                <!-- Блок резервного копирования -->
                <Border Background="#FF1F2937" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="💾 РЕЗЕРВНОЕ КОПИРОВАНИЕ" Style="{StaticResource SectionTitleStyle}"/>

                        <WrapPanel Orientation="Horizontal">
                            <Button Content="💾 Создать backup" Click="CreateBackupClick" 
                                    Background="#FF10B981" MinWidth="130"/>
                            <Button Content="📂 Открыть папку backups" Click="OpenBackupsFolderClick" 
                                    Background="#FF3B82F6" MinWidth="160"/>
                        </WrapPanel>

                        <CheckBox x:Name="AutoBackupCheck" 
                                  Content="🔒 Автоматическое резервное копирование при закрытии приложения"
                                  IsChecked="True"/>

                        <TextBlock Text="Рекомендуется регулярно создавать резервные копии данных"
                                   FontSize="10" Foreground="#FF6B7280" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Блок о системе (информационный) -->
                <Border Background="#FF1F2937" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="ℹ️ О СИСТЕМЕ" Style="{StaticResource SectionTitleStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Версия:" Grid.Column="0" Foreground="#FF9CA3AF" Margin="0,0,0,6"/>
                            <TextBlock Text="1.0.0" Grid.Column="1" Margin="0,0,0,6"/>

                            <TextBlock Text="Разработчик:" Grid.Column="0" Foreground="#FF9CA3AF" Margin="0,0,0,6"/>
                            <TextBlock Text="АИС ПВЗ Team" Grid.Column="1" Margin="0,0,0,6"/>

                            <TextBlock Text="База данных:" Grid.Column="0" Foreground="#FF9CA3AF" Margin="0,0,0,6"/>
                            <TextBlock Text="SQLite" Grid.Column="1" Margin="0,0,0,6"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки действий -->
        <Border Grid.Row="2" Background="Transparent" Padding="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Сообщение о статусе (если есть) -->
                <TextBlock Grid.Column="0" x:Name="StatusMessage" 
                           Text="{Binding StatusMessage}" 
                           Foreground="#FF4ADE80" FontSize="11" 
                           VerticalAlignment="Center" 
                           Visibility="Collapsed"/>

                <Button Grid.Column="1" Content="💾 Сохранить изменения" 
                        Click="SaveClick" Background="#FF10B981" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="❌ Закрыть" 
                        Click="CloseClick" Background="#FF374151"/>
            </Grid>
        </Border>
    </Grid>
</Window>