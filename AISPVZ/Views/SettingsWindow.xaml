<Window x:Class="AISPVZ.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="550" Width="650"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="НАСТРОЙКИ СИСТЕМЫ" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Настройка параметров работы ПВЗ" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Основная область -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
            <StackPanel>

                <!-- Блок основных настроек -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Основные настройки" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="{StaticResource AccentBrush}"/>

                        <TextBlock Text="Название ПВЗ" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                        <TextBox x:Name="PvzNameBox" Text="ПВЗ Центральный"
                                 ToolTip="Введите название..."
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Адрес" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="AddressBox" Text="г. Москва, ул. Примерная, д. 1"
                                 ToolTip="Введите адрес..."
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Максимальный срок хранения (дней)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="MaxDaysBox" Text="7" Width="150" HorizontalAlignment="Left"
                                 ToolTip="7"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Напоминание о просрочке (часов)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="ReminderHoursBox" Text="24" Width="150" HorizontalAlignment="Left"
                                 ToolTip="24"
                                 Margin="0,0,0,12"/>
                    </StackPanel>
                </Border>

                <!-- Блок резервного копирования -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Резервное копирование" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"/>

                        <WrapPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="&#xE7B8;  Создать backup" Click="CreateBackupClick"
                                    Style="{StaticResource AccentButtonStyle}"/>
                            <Button Content="&#xE8B7;  Открыть папку backups" Click="OpenBackupsFolderClick"
                                    Style="{StaticResource ButtonRevealStyle}"/>
                        </WrapPanel>

                        <CheckBox x:Name="AutoBackupCheck"
                                  Content="Автоматическое резервное копирование при закрытии приложения"
                                  IsChecked="True"
                                  Margin="0,12,0,0"/>

                        <TextBlock Text="Рекомендуется регулярно создавать резервные копии данных"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Блок о системе -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="18">
                    <StackPanel>
                        <TextBlock Text="О системе" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Версия:" Grid.Row="0" Grid.Column="0" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="1.0.0" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Text="Разработчик:" Grid.Row="1" Grid.Column="0" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="АИС ПВЗ Team" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Text="База данных:" Grid.Row="2" Grid.Column="0" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="SQL Server" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки действий -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="StatusMessage"
                       Text="{Binding StatusMessage}"
                       Foreground="{StaticResource SuccessBrush}" FontSize="11"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <Button Grid.Column="1" Content="Сохранить изменения"
                    Click="SaveClick" Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Закрыть"
                    Click="CloseClick" Style="{StaticResource ButtonRevealStyle}"/>
        </Grid>
    </Grid>
</Window>
