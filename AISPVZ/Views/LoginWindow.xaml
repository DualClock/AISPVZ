<Window x:Class="AISPVZ.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АИС ПВЗ - Вход в систему"
        Width="400" Height="452"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1E1E2E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3D3D5C"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Background" Value="#FF6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
            <TextBlock Text="АИС ПВЗ" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FF6366F1"/>
            <TextBlock Text="Автоматизированная информационная система&#x0a;Пункт выдачи заказов" FontSize="12" TextAlignment="Center" Foreground="#FF9CA3AF" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Логин"/>
            <TextBox x:Name="LoginBox" Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                     TabIndex="0"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="PasswordBox" TabIndex="1"
                         PasswordChanged="PasswordBox_PasswordChanged"
                         FontSize="16" Padding="10,8" Margin="0,5,0,15"
                         Background="#FF2D2D44" Foreground="White" BorderBrush="#FF3D3D5C"/>

            <TextBlock x:Name="ErrorText" Text="{Binding ErrorMessage}"
                       Foreground="#FFEF4444" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisConv}}"/>

            <Button Content="Войти (Enter)" Command="{Binding LoginCommand}"
                    IsDefault="True" Margin="0,10,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF818CF8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>