<Window x:Class="AISPVZ.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AISPVZ.Converters"
        Title="АИС ПВЗ - Вход в систему"
        Width="420" Height="588"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <SolidColorBrush x:Key="LoginAccentBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="LoginBackgroundBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="LoginSurfaceBrush" Color="#2D2D44"/>
        <SolidColorBrush x:Key="LoginErrorBrush" Color="#EF4444"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConv"/>
        <local:NullToVisibilityConverter x:Key="NullToVisConv"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource LoginAccentBrush}" Padding="0,40,0,40">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="АИС ПВЗ" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="0,12,0,4"/>
                <TextBlock Text="Автоматизированная информационная система&#x0a;Пункт выдачи заказов" 
                           FontSize="12" TextAlignment="Center" Foreground="#CCFFFFFF"/>
            </StackPanel>
        </Border>

        <!-- Login Form -->
        <StackPanel Grid.Row="1" Margin="40,30,40,20" VerticalAlignment="Center">
            <TextBlock Text="Вход в систему" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20" Foreground="White"/>

            <TextBlock Text="Логин" FontSize="12" Margin="0,0,0,4" Opacity="0.8" Foreground="White"/>
            <TextBox x:Name="LoginBox" 
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Введите логин"
                     FontSize="14"
                     Margin="0,0,0,16"
                     Background="{StaticResource LoginSurfaceBrush}"
                     Foreground="White"
                     BorderBrush="#3D3D5C"
                     Padding="10,8"
                     CaretBrush="White"/>

            <TextBlock Text="Пароль" FontSize="12" Margin="0,0,0,4" Opacity="0.8" Foreground="White"/>
            <PasswordBox x:Name="PasswordBox"
                         ToolTip="Введите пароль"
                         PasswordChanged="PasswordBox_PasswordChanged"
                         FontSize="14"
                         Margin="0,0,0,8"
                         Background="{StaticResource LoginSurfaceBrush}"
                         Foreground="White"
                         BorderBrush="#3D3D5C"
                         Padding="10,8"
                         CaretBrush="White"/>

            <TextBlock x:Name="ErrorText" 
                       Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource LoginErrorBrush}" 
                       FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisConv}}"/>

            <Button Content="Войти" 
                    Command="{Binding LoginCommand}"
                    IsDefault="True"
                    HorizontalAlignment="Stretch"
                    Margin="0,10,0,0"
                    Padding="0,12"
                    Background="{StaticResource LoginAccentBrush}"
                    Foreground="White"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
