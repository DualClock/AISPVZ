<Window x:Class="AISPVZ.Views.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиенты" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        MinWidth="850" MinHeight="500"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="КЛИЕНТЫ" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Управление базой клиентов" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Search and Actions -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" 
                CornerRadius="8" Padding="12" Margin="0,0,0,16">
            <WrapPanel Orientation="Horizontal">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Width="280"
                         ToolTip="Поиск по ФИО или телефону..."
                         Margin="0,0,8,0"/>
                <Button Content="Поиск" Command="{Binding SearchCommand}" Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="Добавить" Command="{Binding StartAddCommand}" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="Изменить" Command="{Binding StartEditCommand}" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="Заказы" Command="{Binding ShowClientOrdersCommand}" Style="{StaticResource DefaultButtonStyle}"/>
                <Button Content="Экспорт" Style="{StaticResource ButtonRevealStyle}" Click="ExportClick"/>
                <Button Content="Excel" Style="{StaticResource ButtonRevealStyle}" Click="ExportExcelClick"/>
            </WrapPanel>
        </Border>

        <!-- Main Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Clients Table -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Clients}"
                      SelectedItem="{Binding SelectedClient}"
                      AutoGenerateColumns="False"
                      Margin="0,0,12,0"
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ФИО КЛИЕНТА" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="ТЕЛЕФОН" Binding="{Binding Phone}" Width="160"/>
                    <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Right Panels Stack -->
            <StackPanel Grid.Column="1">

                <!-- Edit Panel -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="18"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
                    <StackPanel>
                        <TextBlock Text="ДАННЫЕ КЛИЕНТА" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <TextBlock Text="ФИО *" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                        <TextBox Text="{Binding FullName}"
                                 ToolTip="Фамилия Имя Отчество"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Телефон" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Phone}"
                                 ToolTip="+7 (999) 999-99-99"
                                 helpers:PhoneMaskBehavior.IsEnabled="True"
                                 xmlns:helpers="clr-namespace:AISPVZ.Helpers"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Email" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Email}"
                                 ToolTip="email@example.com"
                                 Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Сохранить" Command="{Binding SaveClientCommand}" Style="{StaticResource AccentButtonStyle}"/>
                            <Button Content="Отмена" Command="{Binding CancelEditCommand}" Style="{StaticResource ButtonRevealStyle}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Client Orders Panel -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="18"
                        Visibility="{Binding ShowOrders, Converter={StaticResource BoolToVisConv}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ЗАКАЗЫ КЛИЕНТА" FontSize="14" FontWeight="SemiBold" Grid.Column="0" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Grid.Column="1" Command="{Binding HideOrdersCommand}"
                                    Style="{StaticResource ButtonRevealStyle}" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Padding="8,4"/>
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{Binding ClientOrders}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="350">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,6">
                                        <TextBlock Text="{Binding Barcode}" FontWeight="Bold" FontSize="14" FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding CurrentStatus, Converter={StaticResource OrderStatusToTextConv}}"
                                                   Foreground="{StaticResource AccentBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
