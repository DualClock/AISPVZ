<Window x:Class="AISPVZ.Views.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиенты" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        MinWidth="850" MinHeight="500">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#FF6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="32"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- DataGrid Styles -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="50"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF6366F1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2D2D44"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#FF1F2937"/>
            <Setter Property="AlternatingRowBackground" Value="#FF2D2D44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="50"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="👥 КЛИЕНТЫ" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Управление базой клиентов" FontSize="11" Foreground="#FF6B7280" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Search and Actions -->
        <Border Grid.Row="1" Background="#FF1F2937" CornerRadius="10" Padding="12" Margin="0,0,0,16">
            <WrapPanel Orientation="Horizontal">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Width="280" Margin="0,0,8,0" MinWidth="150"/>
                <Button Content="🔍 Поиск" Command="{Binding SearchCommand}" Background="#FF6366F1" Margin="0,0,8,0"/>
                <Button Content="➕ Добавить" Command="{Binding StartAddCommand}" Background="#FF10B981" Margin="0,0,8,0"/>
                <Button Content="✏️ Изменить" Command="{Binding StartEditCommand}" Background="#FF3B82F6" Margin="0,0,8,0"/>
                <Button Content="📦 Заказы" Command="{Binding ShowClientOrdersCommand}" Background="#FFF59E0B" Margin="0,0,8,0"/>
                <Button Content="📎 Экспорт" Background="#FF4B5563" Click="ExportClick"/>
            </WrapPanel>
        </Border>

        <!-- Main Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Clients Table -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Clients}"
                      SelectedItem="{Binding SelectedClient}"
                      AutoGenerateColumns="False"
                      Margin="0,0,12,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ФИО КЛИЕНТА" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="ТЕЛЕФОН" Binding="{Binding Phone}" Width="160"/>
                    <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Right Panels Stack -->
            <StackPanel Grid.Column="1" Margin="0,0,0,0">

                <!-- Edit Panel -->
                <Border Background="#FF1F2937" CornerRadius="10" Padding="18" Margin="0,0,0,16"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
                    <StackPanel>
                        <TextBlock Text="📝 ДАННЫЕ КЛИЕНТА" FontSize="15" FontWeight="Bold" Margin="0,0,0,14"/>

                        <TextBlock Text="ФИО *" Margin="0,0,0,4" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBox Text="{Binding FullName}" Margin="0,0,0,14"/>

                        <TextBlock Text="Телефон" Margin="0,0,0,4" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBox Text="{Binding Phone}" Margin="0,0,0,14"/>

                        <TextBlock Text="Email" Margin="0,0,0,4" FontSize="11" Foreground="#FF9CA3AF"/>
                        <TextBox Text="{Binding Email}" Margin="0,0,0,18"/>

                        <WrapPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить" Command="{Binding SaveClientCommand}" Background="#FF10B981" MinWidth="100"/>
                            <Button Content="❌ Отмена" Command="{Binding CancelEditCommand}" Background="#FF374151" MinWidth="100"/>
                        </WrapPanel>

                        <TextBlock Text="{Binding StatusMessage}" Foreground="#FF4ADE80" Margin="0,14,0,0" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Client Orders Panel -->
                <Border Background="#FF1F2937" CornerRadius="10" Padding="18"
                        Visibility="{Binding ShowOrders, Converter={StaticResource BoolToVisConv}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📋 ЗАКАЗЫ КЛИЕНТА" FontSize="14" FontWeight="Bold" Grid.Column="0"/>
                            <Button Content="✖️" Command="{Binding HideOrdersCommand}"
                                    Background="Transparent" Padding="8,0" FontSize="14"
                                    BorderThickness="0" Foreground="#FF9CA3AF"
                                    Grid.Column="1"/>
                        </Grid>

                        <ListBox Grid.Row="1" ItemsSource="{Binding ClientOrders}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MaxHeight="350">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF2D2D44" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Barcode}" FontWeight="Bold" FontSize="14" FontFamily="Consolas" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding CurrentStatus, Converter={StaticResource OrderStatusToTextConv}}"
                                                       Foreground="#FF6366F1" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                       Foreground="#FF9CA3AF" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>