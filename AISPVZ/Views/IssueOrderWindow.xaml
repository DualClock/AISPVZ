<Window x:Class="AISPVZ.Views.IssueOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выдача заказов" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        MinWidth="950" MinHeight="600"
        Background="{StaticResource BackgroundBrush}"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== LEFT PANEL: ACTIVE ORDERS ========== -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="16" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="АКТИВНЫЕ ЗАКАЗЫ" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Выберите заказ из списка" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Search -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="ПОИСК ПО ШТРИХКОДУ" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BarcodeBox"
                                 Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" FontFamily="Consolas"
                                 ToolTip="Введите штрихкод и нажмите Enter"
                                 KeyDown="BarcodeBox_KeyDown"/>
                        <Button Grid.Column="1" Content="&#xE721;" Command="{Binding SearchByBarcodeCommand}"
                                Style="{StaticResource AccentButtonStyle}" Margin="4,0,0,0" Padding="10,6" FontFamily="Segoe MDL2 Assets"/>
                    </Grid>
                </StackPanel>

                <ListView Grid.Row="2"
                         ItemsSource="{Binding ActiveOrders}"
                         SelectedItem="{Binding SelectedOrder}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0" Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,4">
                                <StackPanel>
                                    <TextBlock Text="{Binding Barcode}"
                                               FontWeight="Bold" FontSize="13"
                                               FontFamily="Consolas"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Client.FullName}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" Margin="0,2,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="6,3">
                                            <TextBlock Text="{Binding Cell.CellCode}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="4" Padding="6,3" Margin="4,0,0,0">
                                            <TextBlock Text="{Binding Marketplace, Converter={StaticResource MarketplaceToTextConv}}"
                                                       FontSize="10" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding PlannedIssueDate, StringFormat='{}{0:dd.MM}'}"
                                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ========== RIGHT PANEL: ORDER DETAILS ========== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{Binding WindowTitle}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding WindowSubtitle}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Order Info Card -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12"
                    Visibility="{Binding IsOrderSelected, Converter={StaticResource BoolToVisConv}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="КЛИЕНТ" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedOrder.Client.FullName}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding SelectedOrder.Client.Phone}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="ЯЧЕЙКА" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedOrder.Cell.CellCode}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="МАРКЕТПЛЕЙС" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedOrder.Marketplace, Converter={StaticResource MarketplaceToTextConv}}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="СРОК ХРАНЕНИЯ" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SelectedOrder.PlannedIssueDate, StringFormat='{}{0:dd.MM.yyyy}'}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Background="{StaticResource ErrorBrush}" CornerRadius="4" Padding="4,2" Margin="0,4,0,0"
                                HorizontalAlignment="Left"
                                Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVisConv}}">
                            <TextBlock Text="ПРОСРОЧЕН" Foreground="White" FontSize="9" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Order Items Content -->
            <Grid Grid.Row="2">
                <!-- Items DataGrid -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16"
                        Visibility="{Binding IsOrderSelected, Converter={StaticResource BoolToVisConv}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="СОСТАВ ЗАКАЗА" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OrderItems}"
                                  SelectedItem="{Binding SelectedOrderItem, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#2A2A2A"
                                  Background="Transparent"
                                  RowBackground="#1E1E1E"
                                  AlternatingRowBackground="#252525"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                                <DataGridTextColumn Header="НАИМЕНОВАНИЕ" Binding="{Binding ProductName}" Width="*" MinWidth="150" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="КОЛ-ВО" Binding="{Binding Quantity}" Width="70" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="ЦЕНА" Binding="{Binding Price, StringFormat=N2}" Width="100" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="СТАТУС" Binding="{Binding StatusText}" Width="100" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Text="{Binding ItemsSummary}" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Right" Margin="0,12,0,0" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </Border>

                <!-- No Order Message -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="40"
                        Visibility="{Binding IsOrderSelected, Converter={StaticResource InvBoolToVisConv}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8B0;" FontFamily="Segoe MDL2 Assets" FontSize="64" Opacity="0.3" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="Отсканируйте штрихкод или выберите заказ из списка слева"
                                   FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Return Reason (visible only in return mode) -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,12,0,0"
                    VerticalAlignment="Bottom"
                    Visibility="{Binding IsReturnMode, Converter={StaticResource BoolToVisConv}}">
                <StackPanel>
                    <TextBlock Text="ПРИЧИНА ВОЗВРАТА *" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding ReturnReasons}"
                              SelectedItem="{Binding SelectedReturnReason}"
                              ToolTip="Выберите причину возврата"
                              HorizontalAlignment="Left" Width="350"/>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Issue Mode Buttons -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsReturnMode, Converter={StaticResource InvBoolToVisConv}}">
                        <Button Content="Выдать всё" Command="{Binding IssueFullCommand}"
                                Style="{StaticResource AccentButtonStyle}" Padding="16,10"/>
                        <Button Content="Выдать выбранное" Command="{Binding IssueSelectedCommand}"
                                Style="{StaticResource DefaultButtonStyle}" Padding="16,10" Margin="8,0,0,0"/>
                        <Button Content="Печать" Command="{Binding PrintReceiptCommand}"
                                Style="{StaticResource ButtonRevealStyle}" Padding="16,10" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Return Mode Buttons -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsReturnMode, Converter={StaticResource BoolToVisConv}}">
                        <Button Content="Оформить возврат" Command="{Binding ProcessReturnCommand}"
                                Style="{StaticResource AccentButtonStyle}" Padding="16,10"/>
                    </StackPanel>

                    <Button Content="Закрыть" Click="CloseButton_Click"
                            Style="{StaticResource ButtonRevealStyle}" Padding="16,10" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Confirmation Modal -->
            <Border Grid.RowSpan="4" Background="#CC000000"
                    Visibility="{Binding ShowConfirmation, Converter={StaticResource BoolToVisConv}}">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="30" Width="450"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="ПОДТВЕРЖДЕНИЕ ОПЕРАЦИИ" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding ConfirmationMessage}" TextAlignment="Center" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,12,0,0" FontSize="13"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="Подтвердить" Command="{Binding ConfirmOperationCommand}"
                                    Style="{StaticResource AccentButtonStyle}" Padding="20,10" MinWidth="120"/>
                            <Button Content="Отмена" Command="{Binding CancelConfirmationCommand}"
                                    Style="{StaticResource ButtonRevealStyle}" Padding="20,10" MinWidth="120" Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
