<Window x:Class="AISPVZ.Views.IssueOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выдача заказа" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        MinWidth="900" MinHeight="550">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Background" Value="#FF6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="36"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MinHeight" Value="48"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF6366F1"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2D2D44"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FF1F2937"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#FF1F2937"/>
            <Setter Property="AlternatingRowBackground" Value="#FF2D2D44"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="48"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== LEFT PANEL: ACTIVE ORDERS LIST ========== -->
        <Border Grid.Column="0" Background="#FF1F2937" CornerRadius="12" Padding="16" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="📋 АКТИВНЫЕ ЗАКАЗЫ" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Выберите заказ из списка" FontSize="11" Foreground="#FF6B7280" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Orders List -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding ActiveOrders}"
                         SelectedItem="{Binding SelectedOrder}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FF2D2D44" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Barcode}"
                                               FontWeight="Bold" FontSize="14"
                                               FontFamily="Consolas"/>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Client.FullName}"
                                               Foreground="#FF9CA3AF"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                                        <Border Background="#FF6366F1" CornerRadius="4" Padding="6,3" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Cell.CellCode}" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <Border Background="#FF374151" CornerRadius="4" Padding="6,3">
                                            <TextBlock Text="{Binding Marketplace, Converter={StaticResource MarketplaceToTextConv}}"
                                                       FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ========== RIGHT PANEL: ORDER DETAILS ========== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="📤 ВЫДАЧА ЗАКАЗА" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="F3 - быстрый доступ | Сканируйте штрихкод или выберите из списка слева" FontSize="11" Foreground="#FF6B7280" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Scanner Input -->
            <Border Grid.Row="1" Background="#FF1F2937" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ШТРИХКОД ЗАКАЗА" FontSize="11" Foreground="#FF6B7280" Margin="0,0,0,4"/>
                        <TextBox x:Name="BarcodeBox" Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="20" FontFamily="Consolas" Background="#FF2D2D44"
                                 Foreground="White" BorderThickness="0" Padding="10,8"
                                 KeyDown="BarcodeBox_KeyDown"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="🔍 Найти" Command="{Binding SearchByBarcodeCommand}"
                            Padding="20,10" Background="#FF6366F1" Margin="12,0,0,0" MinHeight="42"/>
                </Grid>
            </Border>

            <!-- Order Details -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                <Border Background="#FF1F2937" CornerRadius="10" Padding="16"
                        Visibility="{Binding IsOrderFound, Converter={StaticResource BoolToVisConv}}">
                    <StackPanel>
                        <!-- Order Info -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="КЛИЕНТ" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding CurrentOrder.Client.FullName}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CurrentOrder.Client.Phone}" Foreground="#FF9CA3AF" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="ЯЧЕЙКА" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding CurrentOrder.Cell.CellCode}" FontSize="20" FontWeight="Bold" Foreground="#FF6366F1"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="МАРКЕТПЛЕЙС" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding CurrentOrder.Marketplace, Converter={StaticResource MarketplaceToTextConv}}" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="СРОК" FontSize="10" Foreground="#FF6B7280"/>
                                <TextBlock Text="{Binding CurrentOrder.PlannedIssueDate, StringFormat='{}{0:dd.MM.yyyy}'}" FontSize="14"/>
                                <TextBlock Text="ПРОСРОЧЕН" Foreground="#FFEF4444" FontWeight="Bold" FontSize="11"
                                           Visibility="{Binding IsOverdue, Converter={StaticResource BoolToVisConv}}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Items -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="СОСТАВ ЗАКАЗА" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>

                            <Border Grid.Row="1" Background="#FF2D2D44" CornerRadius="8" Padding="8" MinHeight="200">
                                <ListView ItemsSource="{Binding ItemChecks}" Background="Transparent" BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Margin" Value="0,2"/>
                                            <Setter Property="Padding" Value="4"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="35">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Наименование" Width="280"
                                                            DisplayMemberBinding="{Binding Item.ProductName}"/>
                                            <GridViewColumn Header="Кол-во" Width="60"
                                                            DisplayMemberBinding="{Binding Item.Quantity}"/>
                                            <GridViewColumn Header="Цена" Width="90"
                                                            DisplayMemberBinding="{Binding Item.Price, StringFormat=N2}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>
                        </Grid>

                        <!-- Action Buttons -->
                        <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Content="✅ ВЫДАТЬ ПОЛНОСТЬЮ" Command="{Binding RequestFullIssueCommand}"
                                    Background="#FF10B981" Padding="20,12" MinWidth="140"/>
                            <Button Content="📦 ЧАСТИЧНАЯ ВЫДАЧА" Command="{Binding RequestPartialIssueCommand}"
                                    Background="#FF3B82F6" Padding="20,12" MinWidth="150"/>
                            <Button Content="↩️ ВОЗВРАТ" Command="{Binding RequestRefuseCommand}"
                                    Background="#FFF59E0B" Padding="20,12" MinWidth="120"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- No Order Found Message -->
            <Border Grid.Row="2" Background="#FF1F2937" CornerRadius="10" Padding="30"
                    Visibility="{Binding IsOrderFound, Converter={StaticResource InvBoolToVisConv}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Отсканируйте штрихкод или выберите заказ из списка слева"
                               FontSize="16" Foreground="#FF9CA3AF" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="Нажмите Enter для поиска" FontSize="12" Foreground="#FF6B7280" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Bottom Info -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#FF4ADE80" FontSize="13"/>
                    <TextBlock Text="{Binding CurrentOrder.TotalPrice, StringFormat='💰 Итого: {0:N2} ₽'}"
                               Foreground="White" FontSize="14" FontWeight="Bold"
                               Visibility="{Binding IsOrderFound, Converter={StaticResource BoolToVisConv}}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="✖️ Закрыть" Click="CloseButton_Click"
                        Background="#FF374151" Padding="16,8" MinWidth="80"/>
            </Grid>

            <!-- Confirmation Modal -->
            <Border Grid.RowSpan="4" Background="#CC000000"
                    Visibility="{Binding ShowConfirmation, Converter={StaticResource BoolToVisConv}}">
                <Border Background="#FF1F2937" CornerRadius="15" Padding="25" Width="380"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="⚠️ ПОДТВЕРЖДЕНИЕ" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Вы уверены, что хотите продолжить?" TextAlignment="Center" Margin="0,12" TextWrapping="Wrap"/>
                        <WrapPanel HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Button Content="✅ Подтвердить" Command="{Binding ConfirmOperationCommand}"
                                    Background="#FF10B981" Padding="20,10" MinWidth="100"/>
                            <Button Content="❌ Отмена" Command="{Binding CancelConfirmationCommand}"
                                    Background="#FF374151" Padding="20,10" MinWidth="100"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>